# MongoDB Replication Tool - Job Configuration
#
# This configuration was generated by 'mongorep init' command.
# You can edit this file to customize your replication settings.
#
# For full documentation, see: src/rep/config/defaults.yaml
#
# Configuration precedence:
#   1. System defaults (defaults.yaml)
#   2. This file (job-specific overrides)
#   3. CLI arguments (highest priority)

{%- if scan %}

# =============================================================================
# SCAN CONFIGURATION
# =============================================================================
# Controls which collections are scanned for PII and how PII is detected.

scan:
  # Collection Discovery
  # ---------------------
  # Use regex patterns to filter which collections are scanned
  discovery:
    # Include patterns: Only scan collections matching these patterns
    # Empty list = scan all collections
    include_patterns:
{%- if scan.discovery.include_patterns %}
{%- for pattern in scan.discovery.include_patterns %}
      - {{ pattern | tojson }}
{%- endfor %}
{%- else %}
      []  # Scan all collections
{%- endif %}

    # Exclude patterns: Skip collections matching these patterns
    # Applied after include_patterns
    exclude_patterns:
{%- if scan.discovery.exclude_patterns %}
{%- for pattern in scan.discovery.exclude_patterns %}
      - {{ pattern | tojson }}
{%- endfor %}
{%- else %}
      []  # Don't exclude any collections
{%- endif %}

  # Sampling Settings
  # ----------------------
  sampling:
    # Number of documents to analyze per collection
    # Larger sample = more accurate but slower
    sample_size: {{ scan.sampling.sample_size }}

    # Sampling strategy: 'stratified' or 'random'
    # stratified = distributed across collection, random = random selection
    sample_strategy: {{ scan.sampling.sample_strategy }}

  # PII Analysis Settings
  # ----------------------
  # Configure automatic PII analysis using Microsoft Presidio
  pii_analysis:
    enabled: {{ scan.pii_analysis.enabled | lower }}

    # Confidence threshold (0.0-1.0)
    # Higher = fewer false positives, Lower = more sensitive
    confidence_threshold: {{ scan.pii_analysis.confidence_threshold }}

    # PII entity types to detect
    # Common types: EMAIL_ADDRESS, PHONE_NUMBER, PERSON, CREDIT_CARD,
    #                US_SSN, IBAN_CODE, IP_ADDRESS, URL
    entity_types:
{%- for entity_type in scan.pii_analysis.entity_types %}
      - {{ entity_type }}
{%- endfor %}

    # Anonymization strategies per entity type
    # Options:
    #   - redact: Replace with *** (best for sensitive data like SSN)
    #   - hash: SHA-256 hash (best for IDs, maintains uniqueness)
    #   - fake: Generate realistic fake data (best for emails, names)
    default_strategies:
{%- for entity_type, strategy in scan.pii_analysis.default_strategies.items() %}
      {{ entity_type }}: {{ strategy }}
{%- endfor %}

    # Allowlist: Fields to skip PII detection (false positives)
    # Format: collection.field (e.g., users.user_id)
    allowlist:
{%- if scan.pii_analysis.allowlist %}
{%- for item in scan.pii_analysis.allowlist %}
      - '{{ item }}'
{%- endfor %}
{%- else %}
      []  # No allowlist entries
{%- endif %}

    # Presidio configuration file (optional)
    # Use this to define custom PII recognizers via YAML
    # Path can be absolute or relative (resolved in order: cwd, config/, default)
    # Set to null to use default Presidio configuration
    # Example: config/custom_presidio.yaml
    # See: docs/configuration.md and src/mongo_replication/config/presidio.yaml
    presidio_config: {{ scan.pii_analysis.presidio_config | tojson if scan.pii_analysis.presidio_config else 'null' }}

  # Cursor Detection Settings
  # --------------------------
  # Configure which cursor fields to look for during scan
  cursor_detection:
    # List of field names to try as cursor fields for incremental loading (in priority order)
    # The scan command checks for these fields and auto-detects which ones exist
    cursor_fields:
{%- for field in scan.cursor_detection.cursor_fields %}
      - {{ field }}
{%- endfor %}
{%- endif %}

{% if replication %}
# =============================================================================
# REPLICATION CONFIGURATION
# =============================================================================
# Controls how collections are replicated from source to destination.
# This section is typically generated after running 'mongorep scan'.

replication:
  # Collection Discovery
  # ---------------------
  discovery:
    # If true, auto-discover all collections not explicitly configured.
    replicate_all: {{ replication.discovery.replicate_all | lower }}

    # Regex patterns for collections to include (empty = include all).
    include_patterns:
{%- if replication.discovery.include_patterns %}
{%- for item in replication.discovery.include_patterns %}
      - "{{ item }}"
{%- endfor %}
{%- else %}
      []  # Include all collections
{%- endif %}

    # Regex patterns for collections to exclude.
    exclude_patterns:
{%- if replication.discovery.exclude_patterns %}
{%- for item in replication.discovery.exclude_patterns %}
      - "{{ item }}"
{%- endfor %}
{%- else %}
      []  # Exclude no collections
{%- endif %}

  # State Management
  # ---------------------
  # Configuration for replication state tracking.
  state_management:
    # Collection name for storing job run history.
    runs_collection: {{ replication.state_management.runs_collection }}

    # Collection name for storing replication state.
    state_collection: {{ replication.state_management.state_collection }}

  # Performance Settings
  # ---------------------
  performance:
    # Maximum number of collections to replicate concurrently.
    max_parallel_collections: {{ replication.performance.max_parallel_collections }}

    # Number of documents to process in each batch
    batch_size: {{ replication.performance.batch_size }}

  # Default Collection Settings
  # ---------------------------
  # These can be overridden per collection below
  defaults:
    # Field to use when cursor field doesn't exist in a document.
    cursor_fallback_field: {{ replication.defaults.cursor_fallback_field }}

    # Initial cursor value for first-time replication.
    cursor_initial_value: "{{ replication.defaults.cursor_initial_value }}"

    # Default write strategy: merge (upsert), append (insert), replace (drop/recreate).
    write_disposition: {{ replication.defaults.write_disposition }}

    # Default primary key field for merges and deduplication
    primary_key: {{ replication.defaults.primary_key }}

    # How to handle errors during field transformations (fail or skip).
    transform_error_mode : {{ replication.defaults.transform_error_mode }}

  # Collection-specific configuration
  # Override defaults and specify PII fields for each collection
  collections:
{%- if replication.collections %}
{%- for coll_name, coll_config in replication.collections.items() %}
    {{ coll_name }}:
{%- if coll_config.cursor_field %}
      # Field to track incremental changes (e.g., updated_at, _id)
      cursor_field: {{ coll_config.cursor_field | tojson }}
{%- endif %}
      # Write strategy: merge, append, or replace
      write_disposition: {{ coll_config.write_disposition }}
      # Primary key field for merges and deduplication
      primary_key: {{ coll_config.primary_key }}
{%- if coll_config.pii_anonymized_fields %}
      # PII fields and their anonymization strategies
      pii_anonymized_fields:
{%- for field, strategy in coll_config.pii_anonymized_fields.items() %}
        {{ field }}: {{ strategy }}
{%- endfor %}
{%- endif %}
{%- if coll_config.match %}
      # MongoDB filter to select specific documents
      match:
{{ coll_config.match | toyaml(indent=8) | indent(8, first=False) }}
{%- endif %}
{%- if coll_config.field_transforms %}
      # Field transformations (regex replace, etc.)
      field_transforms:
{{ coll_config.field_transforms | toyaml(indent=10) | indent(8, first=False) }}
{%- endif %}
{%- if coll_config.fields_exclude %}
      # Fields to exclude from replication
      fields_exclude:
{%- for field in coll_config.fields_exclude %}
        - {{ field }}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- else %}
      {}  # No collection configured
{%- endif %}


{%- if replication.schema_relationships %}

  # =============================================================================
  # RELATIONSHIPS
  # =============================================================================
  # Define parent-child relationships for cascading replication.
  # Used with --ids or --query option to replicate related data across collections.
  #
  # Example: mongorep run job --ids customers=id1,id2
  # This will replicate specified customers AND their related orders/items.

  schema_relationships:
{%- for rel in replication.schema_relationships %}
    - parent: {{ rel.parent }}
      child: {{ rel.child }}
      # Field in parent collection (usually _id)
      parent_field: {{ rel.parent_field }}
      # Field in child that references parent
      child_field: {{ rel.child_field }}
{%- endfor %}
{%- endif %}
{%- endif %}
