# MongoDB Replication Tool - Job Configuration
#
# This configuration was generated by 'mongorep init' command.
# You can edit this file to customize your replication settings.
#
# For full documentation, see: src/rep/config/defaults.yaml
#
# Configuration precedence:
#   1. System defaults (defaults.yaml)
#   2. This file (job-specific overrides)
#   3. CLI arguments (highest priority)

{%- if scan %}

# =============================================================================
# SCAN CONFIGURATION
# =============================================================================
# Controls which collections are scanned for PII and how PII is detected.

scan:
  # Collection Discovery
  # ---------------------
  # Use regex patterns to filter which collections are scanned
  discovery:
    # Include patterns: Only scan collections matching these patterns
    # Empty list = scan all collections
    include_patterns:
{%- if scan.discovery.include_patterns %}
{% for pattern in scan.discovery.include_patterns %}
      - {{ pattern | tojson }}
{%- endfor %}
{%- else %}
      []  # Scan all collections
{%- endif %}

    # Exclude patterns: Skip collections matching these patterns
    # Applied after include_patterns
    exclude_patterns:
{%- if scan.discovery.exclude_patterns %}
{% for pattern in scan.discovery.exclude_patterns %}
      - {{ pattern | tojson }}
{%- endfor %}
{%- else %}
      []  # Don't exclude any collections
{%- endif %}

  # PII Detection Settings
  # ----------------------
  # Configure automatic PII detection using Microsoft Presidio
  pii:
    enabled: {{ scan.pii.enabled | lower }}

    # Confidence threshold (0.0-1.0)
    # Higher = fewer false positives, Lower = more sensitive
    confidence_threshold: {{ scan.pii.confidence_threshold }}

    # PII entity types to detect
    # Common types: EMAIL_ADDRESS, PHONE_NUMBER, PERSON, CREDIT_CARD,
    #                US_SSN, IBAN_CODE, IP_ADDRESS, URL
    entity_types:
{%- for entity_type in scan.pii.entity_types %}
      - {{ entity_type }}
{%- endfor %}

    # Number of documents to analyze per collection
    # Larger sample = more accurate but slower
    sample_size: {{ scan.pii.sample_size }}

    # Sampling strategy: 'stratified' or 'random'
    # stratified = distributed across collection, random = random selection
    sample_strategy: {{ scan.pii.sample_strategy }}

    # Anonymization strategies per entity type
    # Options:
    #   - redact: Replace with *** (best for sensitive data like SSN)
    #   - hash: SHA-256 hash (best for IDs, maintains uniqueness)
    #   - fake: Generate realistic fake data (best for emails, names)
    default_strategies:
{%- for entity_type, strategy in scan.pii.default_strategies.items() %}
      {{ entity_type }}: {{ strategy }}
{%- endfor %}

    # Allowlist: Fields to skip PII detection (false positives)
    # Format: collection.field (e.g., users.user_id)
    allowlist:
{%- if scan.pii.allowlist %}
{% for item in scan.pii.allowlist %}
      - {{ item }}
{%- endfor %}
{%- else %}
      []  # No allowlist entries
{%- endif %}

    # Presidio configuration file (optional)
    # Use this to define custom PII recognizers via YAML
    # Path can be absolute or relative (resolved in order: cwd, config/, default)
    # Set to null to use default Presidio configuration
    # Example: config/custom_presidio.yaml
    # See: docs/configuration.md and src/mongo_replication/config/presidio.yaml
    presidio_config: {{ scan.pii.presidio_config | tojson if scan.pii.presidio_config else 'null' }}
{%- endif %}
{%- if replication %}

# =============================================================================
# REPLICATION CONFIGURATION
# =============================================================================
# Controls how collections are replicated from source to destination.
# This section is typically generated after running 'mongorep scan'.

replication:
  # Default settings for all collections
  # These can be overridden per collection below
  defaults:
{%- for key, value in replication.defaults.items() %}
{%- if key == 'write_disposition' %}
    # Write strategy: merge (upsert), append (insert), replace (drop/recreate)
{%- elif key == 'fallback_cursor' %}
    # Fallback cursor field when cursor_field doesn't exist
{%- elif key == 'initial_value' %}
    # Initial cursor value for first-time replication
{%- elif key == 'batch_size' %}
    # Documents per batch (higher = faster but more memory)
{%- elif key == 'max_parallel_collections' %}
    # Collections to replicate concurrently
{%- elif key == 'transform_error_mode' %}
    # Error handling: skip (log and continue) or fail (stop replication)
{%- endif %}
    {{ key }}: {{ value | tojson }}
{%- endfor %}

  # Collection-specific configuration
  # Override defaults and specify PII fields for each collection
  collections:
{%- for coll_name, coll_config in replication.collections.items() %}
    {{ coll_name }}:
      # Field to track incremental changes (e.g., updated_at, _id)
      cursor_field: {{ coll_config.cursor_field | tojson }}
      # Write strategy: merge, append, or replace
      write_disposition: {{ coll_config.write_disposition }}
      # Primary key field for merges and deduplication
      primary_key: {{ coll_config.primary_key }}
{%- if coll_config.pii_fields %}
      # PII fields and their anonymization strategies
      pii_fields:
{%- for field, strategy in coll_config.pii_fields.items() %}
        {{ field }}: {{ strategy }}
{%- endfor %}
{%- endif %}
{%- if coll_config.match %}
      # MongoDB filter to select specific documents
      match:
{{ coll_config.match | toyaml(indent=8) | indent(8, first=False) }}
{%- endif %}
{%- if coll_config.field_transforms %}
      # Field transformations (regex replace, etc.)
      field_transforms:
{{ coll_config.field_transforms | toyaml(indent=10) | indent(8, first=False) }}
{%- endif %}
{%- if coll_config.fields_exclude %}
      # Fields to exclude from replication
      fields_exclude:
{%- for field in coll_config.fields_exclude %}
        - {{ field }}
{%- endfor %}
{%- endif %}

{%- endfor %}
{%- if replication.schema %}

  # =============================================================================
  # RELATIONSHIPS
  # =============================================================================
  # Define parent-child relationships for cascading replication.
  # Used with --select option to replicate related data across collections.
  #
  # Example: mongorep run job --select customers=id1,id2
  # This will replicate specified customers AND their related orders/items.

  schema:
{%- for rel in replication.schema %}
    - parent: {{ rel.parent }}
      child: {{ rel.child }}
      # Field in parent collection (usually _id)
      parent_field: {{ rel.parent_field }}
      # Field in child that references parent
      child_field: {{ rel.child_field }}
{%- endfor %}
{%- endif %}
{%- endif %}
